{
  "name": "gxserver",
  "version": "0.1.0",
  "private": true,
  "description": "Ghostex gxserver daemon and shared protocol package.",
  "type": "module",
  "bin": {
    "gxserver": "./dist/src/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol/index.d.ts",
      "default": "./dist/protocol/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run build && npm run test",
    "package:app": "node scripts/package-gxserver.mjs --include-node-modules",
    "package:check": "node scripts/check-package.mjs",
    "package:server": "node scripts/package-gxserver.mjs --generate-homebrew",
    "test": "node --test dist/test/*.test.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "ws": "^8.20.1"
  }
}
